database:
  backend: sqlite           # sqlite | mariadb (デフォルト: sqlite)
  path: ./data/gh_stars.db  # SQLiteバックエンドのパス

  # MariaDB設定 (backend: mariadb の場合に使用)
  mariadb:
    host: 192.168.x.x       # NASのIPアドレス (例: Synology DS223j)
    port: 3306
    user: ghstars_user
    password: ""            # .env の MARIADB_PASSWORD で設定することを推奨
    database: gh_stars

  # ローカルキャッシュ設定 (backend: mariadb かつローカルキャッシュを使う場合)
  # enabled: true にすると NAS MariaDB をマスター、ローカルSQLiteをキャッシュとして扱う
  # C キーでキャッシュの差分更新が可能。NAS切断時もローカルキャッシュで閲覧継続できる。
  cache:
    enabled: false
    path: ./data/gh_stars_cache.db

tagger:
  mode: rule_based               # rule_based | ml | llm
  tags_config_path: config/tags.yaml
  ml_model_path: ~/.local/share/gh_stars/ml_model.pkl

  # Phase 3: LLM Settings
  llm_endpoint: http://localhost:11434
  # 用途やマシンスペックに合わせて以下のいずれかのコメントを外してください
  # llm_model: gemma:2b         # [軽量] 応答速度・省メモリ重視
  llm_model: llama3.2           # [中規模] (デフォルト) 速度と精度のバランス
  # llm_model: command-r-7b     # [大規模] 高い文脈理解性能を重視

sync:
  page_size: 100
